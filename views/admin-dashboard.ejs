<!DOCTYPE html>
<html>
<head>
    <title>Admin Dashboard - RecipeCloud</title>
    <link rel="stylesheet" href="/css/style.css">
    <%- include('navbar') %>
</head>

<body>
    <div class="admin-dashboard-main">
        <h1 class="admin-title">Admin Dashboard</h1>

        <div class="dashboard-grid">
            
            <div class="dashboard-col">
                <div class="admin-metric-card">
                    <h2>Total Users</h2>
                    <p class="metric-number"><%= typeof totalUsers !== 'undefined' ? totalUsers : 20 %></p>
                </div>
                <a href="/admin/users" class="admin-action-link">View All Users</a>
            </div>

            <div class="dashboard-col">
                <div class="admin-metric-card">
                    <h2>Total Recipes</h2>
                    <p class="metric-number"><%= typeof totalRecipes !== 'undefined' ? totalRecipes : 20 %></p>
                </div>
                <a href="/" class="admin-action-link">View All Recipes</a>
            </div>

            <div class="dashboard-col">
                <div class="admin-metric-card">
                    <h2>Total Forum Posts</h2>
                    <p class="metric-number"><%= typeof totalPosts !== 'undefined' ? totalPosts : 0 %></p>
                </div>
                <a href="/forum" class="admin-action-link">View Forum</a>
            </div>

        </div>
        <div class="dashboard-panel">
            <h3>Latest Interactions</h3>
            <div class="activity-feed">

                <div class="activity-item">
                    <div class="activity-content">
                        <span class="activity-type">Forum Post</span>
                        <% if (latestForum) { %>
                            <strong>"<%= latestForum.title %>"</strong> posted by <strong>@<%= latestForum.username %></strong>
                    </div>
                    <div class="activity-meta">
                        <%= latestForum.createdAt.toLocaleDateString('en-UK', { day: 'numeric', month: 'short', hour: '2-digit', minute: '2-digit' }) %>
                    </div>
                        <% } else { %>
                            <span class="empty-state">No forum posts created yet.</span>
                    </div>
                        <% } %>
                </div>

                <div class="activity-item">
                    <div class="activity-content">
                        <span class="activity-type">Comment</span>
                        <% if (latestComment) { %>
                            <strong>@<%= latestComment.username %></strong> commented: "<%= latestComment.comment.length > 50 ? latestComment.comment.substring(0, 50) + '...' : latestComment.comment %>"
                    </div>
                    <div class="activity-meta">
                        <%= latestComment.createdAt.toLocaleDateString('en-UK', { day: 'numeric', month: 'short', hour: '2-digit', minute: '2-digit' }) %>
                    </div>
                        <% } else { %>
                            <span class="empty-state">No comments posted yet.</span>
                    </div>
                        <% } %>
                </div>

                <div class="activity-item">
                    <div class="activity-content">
                        <span class="activity-type">Rating</span>
                        <% if (latestRating) { %>
                            <strong>@<%= latestRating.username %></strong> left a <strong><%= latestRating.ratingValue %>/5 ⭐</strong> rating.
                    </div>
                    <div class="activity-meta">
                        <%= latestRating.createdAt.toLocaleDateString('en-UK', { day: 'numeric', month: 'short', hour: '2-digit', minute: '2-digit' }) %>
                    </div>
                        <% } else { %>
                            <span class="empty-state">No ratings submitted yet.</span>
                    </div>
                        <% } %>
                </div>

            </div>
        </div>
    </div>
</body>
</html>