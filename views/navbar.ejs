<header class="navbar">
    <a href="/" class="navbar-brand">RecipeCloud</a>
    <nav class="navbar-links">
        <a href="/">Home</a>
        <a href="/forum">Community</a>
        <a href="/create">Add Recipe</a>
        <% if (user && user.display_name) { %>
            <div class="user-dropdown">
                <button class="profile-btn">
                    <%= user.display_name %> <div class="arrow" style="display: inline-block;">▼</div>
                </button>
                <div class="dropdown-content">
                    <a href="/display-user/<%= user.id %>">My Profile</a>
                    <a href="/saved-collections">Saved Collections</a>
                    <a href="/shopping-list">Shopping List</a>
                    <div class="dropdown-divider"></div>
                    <a href="/logout">Logout</a>
                </div>
            </div>
        <% } else { %>
            <a href="/login" class="btn-outline">Log In</a>
            <a href="/register" class="btn-solid">Sign Up</a>
        <% } %>
    </nav>
</header>