<h1>My Saved Recipes</h1>

<% favourites.forEach(fav => { %>
    <div style="border: 1px solid #ccc; padding: 15px; margin-bottom: 20px; border-radius: 8px;">
        <h3><%= fav.recipeName %></h3>
        <p><strong>Tags:</strong> <%= fav.tags.join(', ') %></p>
        
        <form action="/favourites/update/<%= fav._id %>" method="POST">
            <label>Edit Notes:</label><br>
            <textarea name="notes" style="width: 100%;"><%= fav.notes %></textarea><br>
            <label>Tags (comma separated):</label><br>
            <input type="text" name="tags" value="<%= fav.tags.join(',') %>" style="width: 100%;"><br>
            <button type="submit" style="margin-top: 5px;">Update Notes/Tags</button>
        </form>

        <div style="margin-top: 15px; display: flex; gap: 10px; align-items: center;">
            <form action="/shopping-list/save-recipe" method="POST">
                <input type="hidden" name="recipeId" value="<%= fav.recipeId %>">
                <input type="hidden" name="recipeName" value="<%= fav.recipeName %>">
                
                <input type="hidden" name="ingredients" value="<%= JSON.stringify(fav.ingredients || []) %>">
                
                <button type="submit" class="btn-solid" style="background-color: #4CAF50; color: rgb(145, 90, 90); border: none; padding: 5px 10px; cursor: pointer;">
                    🛒 Add to Shopping List
                </button>
            </form>

            <form action="/favourites/delete/<%= fav._id %>" method="POST">
                <button type="submit" style="color: red; background: none; border: 1px solid red; padding: 5px 10px; cursor: pointer;">
                    Remove
                </button>
            </form>
        </div>
        
        <div style="margin-top: 10px;">
            <a href="/recipe/<%= fav.recipeId %>">View Original Recipe</a>
        </div>
    </div>
<% }) %>