<h1>My Saved Recipes</h1>

<% if (!favourite || !favourite.savedRecipes || favourite.savedRecipes.length === 0) { %>
    <p>No saved recipes yet. Start building your collection!</p>
<% } else { %>
    <% favourite.savedRecipes.forEach((savedRecipe) => { %>
        <div style="border: 1px solid #ccc; padding: 15px; margin-bottom: 20px; border-radius: 8px;">
            <h3><%= savedRecipe.recipeId %></h3>
            <p><strong>Tags:</strong> <%= favourite.tags.length > 0 ? favourite.tags.join(', ') : 'No tags' %></p>
            <p><strong>Notes:</strong> <%= favourite.notes || 'No notes' %></p>
            
            <form action="/favourites/update" method="POST">
                <label>Edit Notes:</label><br>
                <textarea name="notes" style="width: 100%;"><%= favourite.notes %></textarea><br>
                <label>Tags (comma separated):</label><br>
                <input type="text" name="tags" value="<%= favourite.tags.join(',') %>" style="width: 100%;"><br>
                <label>Ingredients (comma separated):</label><br>
                <input type="text" name="ingredients" value="<%= favourite.ingredients.join(',') %>" style="width: 100%;"><br>
                <button type="submit" style="margin-top: 5px;">Update Notes/Tags</button>
            </form>

            <div style="margin-top: 15px; display: flex; gap: 10px; align-items: center;">
                <form action="/shopping-list/save-recipe" method="POST">
                    <input type="hidden" name="recipeId" value="<%= savedRecipe.recipeId %>">
                    <input type="hidden" name="ingredients" value="<%= JSON.stringify(favourite.ingredients || []) %>">
                    
                    <button type="submit" class="btn-solid" style="background-color: #4CAF50; color: rgb(145, 90, 90); border: none; padding: 5px 10px; cursor: pointer;">
                        🛒 Add to Shopping List
                    </button>
                </form>

                <form action="/favourites/delete/<%= savedRecipe.recipeId %>" method="POST">
                    <button type="submit" style="color: red; background: none; border: 1px solid red; padding: 5px 10px; cursor: pointer;">
                        Remove
                    </button>
                </form>
            </div>
            
            <div style="margin-top: 10px;">
                <a href="/recipe/<%= savedRecipe.recipeId %>">View Original Recipe</a>
            </div>
        </div>
    <% }); %>
<% } %>