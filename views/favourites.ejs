<h1>My Saved Recipes</h1>

<% if (!favourite || !favourite.savedRecipes || favourite.savedRecipes.length === 0) { %>
    <p>No saved recipes yet. Start building your collection!</p>
<% } else { %>
    <% favourite.savedRecipes.forEach((savedRecipe) => { %>
        <div style="border: 1px solid #ccc; padding: 15px; margin-bottom: 20px; border-radius: 8px;">
            
            <h3>Recipe ID: <%= savedRecipe.recipeId %></h3>
            <p>Saved on: <%= savedRecipe.dateSaved.toDateString() %></p>
            
            <form action="/favourites/update" method="POST">
                <input type="hidden" name="recipeId" value="<%= savedRecipe.recipeId %>">
                
                <label>Notes:</label><br>
                <textarea name="notes" style="width: 100%;"><%= savedRecipe.notes || '' %></textarea><br>
                
                <button type="submit" style="margin-top: 5px;">Update Notes</button>
            </form>

            <div style="margin-top: 15px;">
                <form action="/favourites/delete/<%= savedRecipe.recipeId %>" method="POST">
                    <button type="submit" style="color: red; border: 1px solid red; background: none; cursor: pointer; padding: 5px 10px;">
                        Remove from Favourites
                    </button>
                </form>
            </div>
            
            <div style="margin-top: 10px;">
                <a href="/recipe/<%= savedRecipe.recipeId %>">View Recipe Details</a>
            </div>
        </div>
    <% }); %>
<% } %>