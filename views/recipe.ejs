<!DOCTYPE html>
<html>
<head>
    <title><%= recipe.recipe_name %> - RecipeCloud</title>
    <link rel="stylesheet" href="/css/style.css">
    <%- include('navbar') %>
</head>

<body>
    
    
        <div class="recipe-detail-main">
        <div class="recipe-container">

            <div class="image-wrapper">
                <% if (recipe.image && recipe.image.startsWith('data:image')) { %>
                    <img src="<%= recipe.image %>" >
                <% } else { %>
                    <img src="/img/default-recipe.png" >
                <% } %>
            </div>

        
            <div class="content-wrapper">
                
                <div class="header-wrapper">
                    <div class="title-owner-wrapper">
                        <div class="title-row">
                            <h1 class="recipe-detail-title"><%= recipe.recipe_name %></h1>

                            <% if (user && String(user.id) === String(recipe.userId)) { %>
                                <div class="recipe-owner-actions">
                                    <a href="/recipe/<%= recipe._id %>/update" class="btn-solid">Update</a>
                                    <a href="/recipe/<%= recipe._id %>/delete" class="btn-solid">Delete</a>
                                </div>
                            <% } %>
                        </div>

                        <p class="recipe-created-by">Created by <%= recipe.username %></p>
                    </div>

                    <div class="rating-badge">
                        ⭐ <%= (typeof ratingAverage === 'number' ? ratingAverage.toFixed(1) : 'New!') %> / 5
                        (<%= ratingCount || 0 %> ratings)

                    </div>
                    <br>
                </div>

                <% if (user) { %>
                    <div class="rating-form-wrapper">
                        <form action="/recipe/<%= recipe._id %>/rate" method="POST" class="rating-form">
                            <label>
                                <% if (userRating !== null) { %>
                                    <strong>Your rating:</strong>
                                <% } else { %>
                                    <strong>Rate this recipe:</strong>
                                <% } %>
                            </label>
                            <select name="rating" class="form-input rating-select">
                                <option value="1" <%= userRating == 1 ? 'selected' : '' %>>1 ⭐</option>
                                <option value="2" <%= userRating == 2 ? 'selected' : '' %>>2 ⭐</option>
                                <option value="3" <%= userRating == 3 ? 'selected' : '' %>>3 ⭐</option>
                                <option value="4" <%= userRating == 4 ? 'selected' : '' %>>4 ⭐</option>
                                <option value="5" <%= userRating == 5 ? 'selected' : '' %>>5 ⭐</option>
                            </select>
                            <button type="submit" class="btn-solid rating-btn">
                                <%= userRating ? "Update Rating" : "Submit Rating" %>
                            </button>
                        </form>
                    </div>
                <% } else { %>
                    <p style="color: gray; margin: 8px 0;">Please login to rate this recipe</p>
                <% } %>

                <% if (user) { %>
        <div class="rating-form-wrapper" style="margin-top: 15px; border-top: 1px dashed #ccc; padding-top: 15px;">
            <h3 class="section-heading" style="font-size: 1.1rem; margin-bottom: 10px;">💾 Save to My Collection</h3>
            <form action="/favorites/add" method="POST" class="rating-form" style="flex-direction: column; align-items: flex-start; gap: 10px;">
                <input type="hidden" name="recipeId" value="<%= recipe._id %>">
                <input type="hidden" name="recipeName" value="<%= recipe.recipe_name %>">
                
                <div style="width: 100%;">
                    <label><strong>Tags:</strong> (e.g. Spicy, Dessert, Easy)</label>
                    <input type="text" name="tags" class="form-input" placeholder="Enter tags separated by commas" style="width: 100%; margin-top: 5px;">
                </div>

                <div style="width: 100%;">
                    <label><strong>Personal Notes:</strong></label>
                    <textarea name="notes" class="recipe-comment-textarea" placeholder="Why do you love this recipe?" style="min-height: 60px; margin-top: 5px;"></textarea>
                </div>
                
                <button type="submit" class="btn-solid" style="background-color: #e91e63; border-color: #e91e63;">
                    ❤️ Add to Favorites
                </button>
            </form>
        </div>
    <% } %>

                <div class="meta-info">
                    <label><strong>🍽️ Cuisine:</strong> <%= recipe.cuisine %></label>
                    <label><strong>⏱️ Time:</strong> <%= recipe.approx_cooking_time %></label>
                    <label><strong>📊 Difficulty:</strong> <label class="capitalize-text"><%= recipe.difficulty_level %></label></label>
                    <label><strong>👥 Servings:</strong> <%= recipe.serving %></label> 
                </div>

                <div class="tags-container">
                    <% recipe.tag.forEach(function(t) { %>
                        <label class="tag-badge"><%= t %></label>
                    <% }); %>
                </div>

                <div class="recipe-divider"></div>

                <div class="ratings-section">
                    <h3 class="section-heading">All Ratings (<%= allRatings.length %>)</h3>
                    
                    <% if (allRatings.length === 0) { %>
                        <p class="no-ratings-text">No ratings yet.</p>
                    <% } else { %>
                        <div class="ratings-list">
                            <% allRatings.forEach(rating => { %>
                                <div class="rating-item">
                                    <div class="rating-item-header">
                                        <div class="rating-item-user"><strong><%= rating.username %></strong></div>
                                        <div class="rating-item-stars">
                                            <% for (let i = 0; i < rating.ratingValue; i++) { %>⭐<% } %> <%= rating.ratingValue %>/5
                                        </div>
                                    </div>
                                    <div class="rating-item-timestamp">
                                        <%= rating.createdAt.toLocaleDateString('en-UK', { day: 'numeric', month: 'long', year: 'numeric' }) %>
                                        <% if (rating.updatedAt && rating.updatedAt.getTime() !== rating.createdAt.getTime()) { %>
                                            <% if (rating.isEdited) { %>
                                                <%= console.log(rating.updatedAt, rating.createdAt) %>
                                                <span class="rating-edited-tag">(updated)</span>
                                            <% } %>
                                        <% } %>
                                    </div>
                                </div>
                            <% }); %>
                        </div>
                    <% } %>
                </div>

                <div class="grid-layout">
                    
                    <div class="ingredients-sidebar">
                        <h3 class="section-heading">Ingredients</h3>
                        <ul class="ingredient-list">
                            <% if (recipe.ingredients && recipe.ingredients.length > 0) { %>
                                <% recipe.ingredients.forEach(function(ingredient) { %>
                                    <li>
                                        <div><%= ingredient.name %></div>
                                        <div class="recipe-ing-amount"><%= ingredient.amount %></div>
                                    </li>
                                <% }); %>
                            <% } else { %>
                                <li class="empty-list-item">No ingredients listed.</li>
                            <% } %>
                        </ul>
                    </div>

                    <div>
                        <h3 class="section-heading">Instructions</h3>
                        <div class="instructions-container"><%= recipe.instructions %></div>
                    </div>

                </div>
                <div class="recipe-comments-section">
                    <div class="comment-form-card">
                        <h3 class="section-heading">Comments</h3>

                        <% if (user) { %>
                            <% if (status && status === 'success') { %>
                                <p class="comment-success">Comment added successfully</p>
                            <% } else if (status && status === 'error') { %>
                                <p class="comment-error">Failed to add comment</p>
                            <% } %>
                            <form action="/recipe/<%= recipe._id %>/comment" method="POST" class="recipe-comment-form">
                                <div class="comment-user-display">
                                    Posting as <strong><%= user.userName %></strong>
                                </div>

                                <textarea 
                                    name="comment" 
                                    class="recipe-comment-textarea" 
                                    placeholder="Write a comment about this recipe..." 
                                    required></textarea>

                                <button type="submit" class="btn-solid recipe-comment-submit-btn">
                                    Post Comment
                                </button>
                            </form>
                        <% } else { %>
                            <div class="comment-login-box">
                                <p class="comment-login-text">
                                    You must be logged in to post a comment.
                                </p>

                                <div class="comment-login-actions">
                                    <a href="/login" class="btn-solid comment-login-btn">Log In</a>
                                    <a href="/register" class="btn-solid comment-signup-btn">Sign Up</a>
                                </div>
                            </div>
                        <% } %>
                    </div>

                    <div class="comment-list-card">
                        <h3 class="section-heading">All Comments (<%= comments.length %>)</h3>

                        <% if (comments.length === 0) { %>
                            <p class="no-comments-text">No comments yet.</p>
                        <% } %>

                        <% comments.forEach(c=> { %>
                            <div class="recipe-comment-item">
                                <div class="recipe-comment-header">
                                    <div class="recipe-comment-username"><%= c.username %></div>
                                    <div class="recipe-comment-meta">
                                        <%= c.createdAt.toLocaleDateString('en-UK', { day: 'numeric', month: 'short', year: 'numeric' }) %>
                                        <% if (c.isEdited) { %>
                                            <div class="comment-edited-tag">(edited)</div>
                                        <% } %>
                                    </div>
                                </div>
                                <div class="recipe-comment-body"><%= c.comment %></div>
                                <% if (user && user.id.toString() === c.userId.toString()) { %>
                                    <div class="recipe-comment-actions">
                                        <button class="btn-comment-edit"
                                                onclick="openEditOverlay('<%= c._id %>', '<%= recipe._id %>', `<%= c.comment %>`)">
                                            Edit
                                        </button>
                                        <button class="btn-comment-delete"
                                                onclick="openDeleteOverlay('<%= c._id %>', '<%= recipe._id %>')">
                                            Delete
                                        </button>
                                    </div>
                                <% } %>
                                </div>
                        <% }); %>
                    </div>
                </div>
                <div class="back-link-container">
                    <a href="/" class="back-link">
                        &larr; Back to Recipes
                    </a>
                </div>
            </div>
        </div>
    </div>
    <!-- DELETE OVERLAY -->
    <div class="overlay-backdrop" id="deleteOverlay">
        <div class="overlay-box">
            <h3 class="overlay-title">Delete Comment</h3>
            <p class="overlay-body-text">Are you sure you want to delete this comment? This cannot be undone.</p>
            <div class="overlay-actions">
                <button type="button" class="btn-outline" onclick="closeDeleteOverlay()">Cancel</button>
                <form id="deleteCommentForm" method="POST">
                    <button type="submit" class="btn-solid">Confirm Delete</button>
                </form>
            </div>
        </div>
    </div>

    <!-- EDIT OVERLAY -->
    <div class="overlay-backdrop" id="editOverlay">
        <div class="overlay-box">
            <h3 class="overlay-title">Edit Comment</h3>
            <form id="editCommentForm" method="POST">
                <div class="input-group">
                    <label>Comment:</label>
                    <textarea id="editCommentTextarea" name="comment" class="recipe-comment-textarea"></textarea>
                </div>
                <div class="overlay-actions">
                    <button type="button" class="btn-outline" onclick="closeEditOverlay()">Cancel</button>
                    <button type="submit" class="btn-solid">Save Changes</button>
                </div>
            </form>
        </div>
    </div>

    <script>
        // DELETE
        function openDeleteOverlay(commentId, recipeId) {
            document.getElementById('deleteCommentForm').action = `/recipe/${recipeId}/comment/${commentId}/delete`;
            document.getElementById('deleteOverlay').classList.add('overlay-visible');
        }

        function closeDeleteOverlay() {
            document.getElementById('deleteOverlay').classList.remove('overlay-visible');
        }

        // EDIT
        function openEditOverlay(commentId, recipeId, currentComment) {
            document.getElementById('editCommentForm').action = `/recipe/${recipeId}/comment/${commentId}/edit`;
            document.getElementById('editCommentTextarea').value = currentComment;
            document.getElementById('editOverlay').classList.add('overlay-visible');
        }

        function closeEditOverlay() {
            document.getElementById('editOverlay').classList.remove('overlay-visible');
        }

        // Close on backdrop click — wrapped in null checks
        const deleteOverlay = document.getElementById('deleteOverlay');
        const editOverlay = document.getElementById('editOverlay');

        if (deleteOverlay) {
            deleteOverlay.addEventListener('click', function(e) {
                if (e.target === this) closeDeleteOverlay();
            });
        }

        if (editOverlay) {
            editOverlay.addEventListener('click', function(e) {
                if (e.target === this) closeEditOverlay();
            });
        }
    </script>
</body>
</html>