<!DOCTYPE html>
<html>
<head>
    <title><%= recipe.recipe_name %> - RecipeCloud</title>
    <link rel="stylesheet" href="/css/style.css">
    <%- include('navbar') %>
</head>

<body>
    
    <div class="recipe-detail-main">
        <div class="recipe-container">

            <div class="image-wrapper">
                <% if (recipe.image && recipe.image.startsWith('data:image')) { %>
                    <img src="<%= recipe.image %>" >
                <% } else { %>
                    <img src="/img/default-recipe.png" >
                <% } %> 
            </div>

            <div class="content-wrapper">
                
                <% if (typeof favStatus !== 'undefined') { %>
                    <% if (favStatus === 'success') { %>
                        <div class="comment-success action-alert" style="margin-bottom: 25px;">⭐ Successfully added to your collection!</div>
                    <% } else if (favStatus === 'exists') { %>
                        <div class="comment-error action-alert" style="margin-bottom: 25px;">ℹ️ This recipe is already in your collection.</div>
                    <% } %>
                <% } %>

                <div class="recipe-header-modern">
                    
                    <div class="recipe-header-main">
                        <h1 class="recipe-detail-title" style="margin: 0;"><%= recipe.recipe_name %></h1>
                        <p class="recipe-created-by" style="margin: 0;">Created by <strong><%= recipe.username %></strong></p>
                        
                        <div class="header-actions-left">
                            <% if (user) { %>
                                <% if (typeof isFavourited !== 'undefined' && isFavourited) { %>
                                    <div class="btn-saved-header">⭐ In <a href="/favourites">Saved</a></div>
                                <% } else { %>
                                    <form action="/favourites/add" method="POST" style="margin: 0;">
                                        <input type="hidden" name="recipeId" value="<%= recipe._id %>">
                                        <input type="hidden" name="recipeName" value="<%= recipe.recipe_name %>">
                                        <button type="submit" class="btn-favourite-header">❤️ Save Recipe</button>
                                    </form>
                                <% } %>
                            <% } %>

                            <div class="tags-container" style="margin: 0;">
                                <% recipe.tag.forEach(function(t) { %>
                                    <label class="tag-badge" style="margin: 0;"><%= t %></label>
                                <% }); %>
                            </div>
                        </div>
                    </div>

                    <div class="recipe-header-side">
                        
                        <div class="rating-group-top">
                            <div class="rating-badge">
                                <span>⭐</span>
                                <span class="rating-average">
                                    <%= (typeof ratingAverage === 'number' ? ratingAverage.toFixed(1) : 'New!') %> / 5
                                </span>
                                <span class="rating-count-bold">
                                    (<%= ratingCount || 0 %>)
                                </span>
                            </div>

                            <% if (user) { %>
                                <form action="/recipe/<%= recipe._id %>/rate" method="POST" class="rating-form-inline">
                                    <select name="rating" class="rating-select-small">
                                        <option value="1" <%= userRating == 1 ? 'selected' : '' %>>1 ⭐</option>
                                        <option value="2" <%= userRating == 2 ? 'selected' : '' %>>2 ⭐</option>
                                        <option value="3" <%= userRating == 3 ? 'selected' : '' %>>3 ⭐</option>
                                        <option value="4" <%= userRating == 4 ? 'selected' : '' %>>4 ⭐</option>
                                        <option value="5" <%= userRating == 5 ? 'selected' : '' %>>5 ⭐</option>
                                    </select>
                                    <button type="submit" class="btn-solid rating-btn-small"><%= userRating ? "Update" : "Rate" %></button>
                                </form>
                            <% } %>
                        </div>

                        <!-- Ratings List -->
                        <div class="ratings-display" style="margin-top: 20px; padding: 15px; background: #f9f9f9; border-radius: 8px; max-height: 300px; overflow-y: auto;">
                            <h4 style="margin-top: 0; margin-bottom: 15px; font-size: 14px; font-weight: bold;">All Ratings</h4>
                        <% if (user && currentRecipeRating) { %>
                            <div style="margin-bottom: 12px; padding-bottom: 12px; border-bottom: 1px solid #e0e0e0;">
                            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 4px;">
                                <span style="font-size: 14px;">
                                    <% for (let i = 0; i < currentRecipeRating.ratingValue; i++) { %>⭐<% } %> <%= currentRecipeRating.ratingValue %>/5
                                </span>
                                </div>
                                <div style="font-size: 12px; color: #666;">
                                    Your rating on <%= currentRecipeRating.dateSaved.toLocaleDateString('en-UK', { day: 'numeric', month: 'short', year: 'numeric' }) %>
                                    <% if (currentRecipeRating.isEdited) { %>
                                <span style="color: #999;">(updated)</span>
                                <% } %>
                            <% } else { %>
                                <p style="margin: 0; color: #999; font-size: 14px;">No ratings yet.</p>
                            <% } %>


                        
                        <% if (user && (String(user.id) === String(recipe.userId) || user.role === "admin")) { %>
                            <div class="recipe-owner-links" style="display: flex; gap: 10px; justify-content: flex-end; width: 100%;">
                                <a href="/recipe/<%= recipe._id %>/update" class="btn-outline-small">✏️ Edit Recipe</a>
                                <a href="/recipe/<%= recipe._id %>/delete" class="btn-outline-small text-danger">🗑️ Delete</a>
                            </div>
                        <% } %>
                    </div>
                </div>

                <% if (!user) { %>
                    <p class="login-prompt-text" style="margin-bottom: 25px;">Please <a href="/login" style="color: #E0A840;">log in</a> to rate and save this recipe.</p>
                <% } %>

                <div class="recipe-quick-stats">
                    <div class="stat-item"><strong>🍽️ Cuisine</strong><%= recipe.cuisine %></div>
                    <div class="stat-item"><strong>⏱️ Time</strong><%= recipe.approx_cooking_time %></div>
                    <div class="stat-item"><strong>📊 Difficulty</strong><span class="capitalize-text"><%= recipe.difficulty_level %></span></div>
                    <div class="stat-item"><strong>👥 Servings</strong><%= recipe.serving %></div>
                </div>

                <div class="recipe-divider"></div>

                <div class="grid-layout">
                    
                    <div class="ingredients-sidebar">
                        <h3 class="section-heading">Ingredients</h3>
                        <ul class="ingredient-list">
                            <% if (recipe.ingredients && recipe.ingredients.length > 0) { %>
                                <% recipe.ingredients.forEach(function(ingredient) { %>
                                    <li>
                                        <div><%= ingredient.name %></div>
                                        <div class="recipe-ing-amount"><%= ingredient.amount %></div>
                                    </li>
                                <% }); %>
                            <% } else { %>
                                <li class="empty-list-item">No ingredients listed.</li>
                            <% } %>
                        </ul>
                    </div>

                    <div>
                        <h3 class="section-heading">Instructions</h3>
                        <div class="instructions-container"><%= recipe.instructions %></div>
                    </div>

                </div>
                <div class="recipe-comments-section">
                    <div class="comment-form-card">
                        <h3 class="section-heading">Comments</h3>

                        <% if (user) { %>
                            <% if (status && status === 'success') { %>
                                <p class="comment-success">Comment added successfully</p>
                            <% } else if (status && status === 'error') { %>
                                <p class="comment-error">Failed to add comment</p>
                            <% } %>
                            <form action="/recipe/<%= recipe._id %>/comment" method="POST" class="recipe-comment-form">
                                <div class="comment-user-display">
                                    Posting as <strong><%= user.userName %></strong>
                                </div>

                                <textarea 
                                    name="comment" 
                                    class="recipe-comment-textarea" 
                                    placeholder="Write a comment about this recipe..." 
                                    required></textarea>

                                <button type="submit" class="btn-solid recipe-comment-submit-btn">
                                    Post Comment
                                </button>
                            </form>
                        <% } else { %>
                            <div class="comment-login-box">
                                <p class="comment-login-text">
                                    You must be logged in to post a comment.
                                </p>

                                <div class="comment-login-actions">
                                    <a href="/login" class="btn-solid comment-login-btn">Log In</a>
                                    <a href="/register" class="btn-solid comment-signup-btn">Sign Up</a>
                                </div>
                            </div>
                        <% } %>
                    </div>

                    <div class="comment-list-card">
                        <h3 class="section-heading">All Comments (<%= comments.length %>)</h3>

                        <% if (comments.length === 0) { %>
                            <p class="no-comments-text">No comments yet.</p>
                        <% } %>

                        <% comments.forEach(c=> { %>
                            <div class="recipe-comment-item">
                                <div class="recipe-comment-header">
                                    <div class="recipe-comment-username"><%= c.username %></div>
                                    <div class="recipe-comment-meta">
                                        <%= c.createdAt.toLocaleDateString('en-UK', { day: 'numeric', month: 'short', year: 'numeric' }) %>
                                        <% if (c.isEdited) { %>
                                            <div class="comment-edited-tag">(edited)</div>
                                        <% } %>
                                    </div>
                                </div>
                                <div class="recipe-comment-body"><%= c.comment %></div>
                                <% if (user && user.id.toString() === c.userId.toString()) { %>
                                    <div class="recipe-comment-actions">
                                        <a href="/recipe/<%= recipe._id %>/comment/<%= c._id %>/edit" class="btn-comment-edit" style="text-decoration: none; display: inline-block; text-align: center;">
                                            Edit
                                        </a>
                                        <form action="/recipe/<%= recipe._id %>/comment/<%= c._id %>/delete" method="POST" style="display: inline; margin: 0;">
                                            <button type="submit" class="btn-comment-delete">
                                                Delete
                                            </button>
                                        </form>
                                    </div>
                                <% } %>
                            </div>
                        <% }); %>
                    </div>
                </div>
                <div class="back-link-container">
                    <a href="/" class="back-link">
                        &larr; Back to Recipes
                    </a>
                </div>
            </div>
        </div>
    </div>
</body>
</html>
            </div>
            <div class="overlay-actions">
                <button type="button" class="btn-outline" onclick="closeRatingsOverlay()">Close</button>
            </div>
        </div>
    </div>

    <script>
        // RATINGS
        function openRatingsOverlay() {
            document.getElementById('ratingsOverlay').classList.add('overlay-visible');
        }

        function closeRatingsOverlay() {
            document.getElementById('ratingsOverlay').classList.remove('overlay-visible');
        }
        // Close ratings overlay on backdrop click
        const ratingsOverlay = document.getElementById('ratingsOverlay');
        if (ratingsOverlay) {
            ratingsOverlay.addEventListener('click', function(e) {
                if (e.target === this) closeRatingsOverlay();
            });
        }
    </script>
</body>
</html>