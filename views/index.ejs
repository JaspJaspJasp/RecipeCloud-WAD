<!DOCTYPE html>
<html>
<head>
    <title>Home - RecipeCloud</title>
    <link rel="stylesheet" href="/css/style.css">
    <%- include('navbar') %>
    

</head>

<body>
    <div>
        <div class="hero-container">
            <div class="home-title">Discover & Share Delicious Recipes</div>
            <div class="home-subtitle">by G2</div>

            <form action="/" method="GET" class="search-form" id="mainSearchForm">
                
                <div style="display: flex; gap: 10px; width: 100%; max-width: 800px; margin: 0 auto;">
                    <input type="text" name="q" placeholder="Search by name..." value="<%= searchQuery || '' %>" class="search-input-large" style="flex-grow: 1;" >
                    <button type="submit" class="search-btn-large">Search</button>
                </div>

                <div class="filter-wrapper">
                    
                    <div class="tags-row">
                        <label class="tag-item"><input type="checkbox" name="tags" value="vegetarian" onchange="this.form.submit()" <%= tag.includes('vegetarian') ? 'checked' : '' %>> Vegetarian</label>
                        <label class="tag-item"><input type="checkbox" name="tags" value="vegan" onchange="this.form.submit()" <%= tag.includes('vegan') ? 'checked' : '' %>> Vegan</label>
                        <label class="tag-item"><input type="checkbox" name="tags" value="gluten free" onchange="this.form.submit()" <%= tag.includes('gluten free') ? 'checked' : '' %>> Gluten Free</label>
                        <label class="tag-item"><input type="checkbox" name="tags" value="appetizer" onchange="this.form.submit()" <%= tag.includes('appetizer') ? 'checked' : '' %>> Appetizer</label>
                        <label class="tag-item"><input type="checkbox" name="tags" value="main" onchange="this.form.submit()" <%= tag.includes('main') ? 'checked' : '' %>> Main</label>
                        <label class="tag-item"><input type="checkbox" name="tags" value="dessert" onchange="this.form.submit()" <%= tag.includes('dessert') ? 'checked' : '' %>> Dessert</label>
                    </div>

                    <div class="dropdown-row">
                        <div style="display: flex; align-items: center;">
                            <label for="cuisine" class="filter-label">Cuisine:</label>
                            <select name="cuisine" id="cuisine" class="filter-select" onchange="this.form.submit()">
                                <option value="" <%= cuisine==='' ? 'selected' : '' %>>All Cuisines</option>
                                <option value="Italian" <%= cuisine==='Italian' ? 'selected' : '' %>>Italian</option>
                                <option value="French" <%= cuisine==='French' ? 'selected' : '' %>>French</option>
                                <option value="Chinese" <%= cuisine==='Chinese' ? 'selected' : '' %>>Chinese</option>
                                <option value="Japanese" <%= cuisine==='Japanese' ? 'selected' : '' %>>Japanese</option>
                                <option value="Korean" <%= cuisine==='Korean' ? 'selected' : '' %>>Korean</option>
                                <option value="Western" <%= cuisine==='Western' ? 'selected' : '' %>>Western</option>
                                <option value="Asian" <%= cuisine==='Asian' ? 'selected' : '' %>>Asian</option>
                            </select>
                        </div>

                        <div style="display: flex; align-items: center;">
                            <label for="difficulty" class="filter-label">Difficulty:</label>
                            <select name="difficulty" id="difficulty" class="filter-select" onchange="this.form.submit()">
                                <option value="" <%= difficulty==='' ? 'selected' : '' %>>All</option>
                                <option value="beginner" <%= difficulty==='beginner' ? 'selected' : '' %>>Beginner</option>
                                <option value="intermediate" <%= difficulty==='intermediate' ? 'selected' : '' %>>Intermediate</option>
                                <option value="advanced" <%= difficulty==='advanced' ? 'selected' : '' %>>Advanced</option>
                            </select>
                        </div>
                    </div>

                    <div class="filter-actions">
                        <a href="/" class="btn-solid">Clear All Filters</a>
                    </div>

                </div>
            </form>
            
        </div>

        <div class="recipe-grid">
            <% if (recipes && recipes.length > 0) { %>
                <% recipes.forEach(function(recipe) { %>
                    <a href="/recipe/<%= recipe._id %>" class="recipe-card-link">
                        
                        <% if (recipe.image && recipe.image.startsWith('data:image')) { %>
                            <img src="<%= recipe.image %>" class="recipe-image">
                        <% } else { %>
                            <img src="/img/default-recipe.png" class="recipe-image">
                        <% } %>

                        <div class="recipe-content">
                            <div class="recipe-title">
                                <%= recipe.recipe_name %>
                            </div>

                            <div class="recipe-author">
                                ⭐ <%= recipe.ratingAverage > 0 ? recipe.ratingAverage.toFixed(1) : 'New!' %> | <%= recipe.cuisine %>
                            </div>

                            <div class="recipe-tags">
                                <strong>Tags:</strong>
                                <%= recipe.tag.join(', ') %>
                            </div>
                        </div>
                    </a>
                <% }); %>
            <% } else { %>
                <div class="no-results">No recipes found matching your filters. Try a different search!</div>
            <% } %>
        </div>
    </div>
</body>
</html>